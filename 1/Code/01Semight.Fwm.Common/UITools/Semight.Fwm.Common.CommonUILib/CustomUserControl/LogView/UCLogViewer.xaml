<UserControl
    x:Class="Semight.Fwm.Common.CommonUILib.CustomUserControl.LogView.UCLogViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Semight.Fwm.Common.CommonUILib.CustomUserControl.LogView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Border x:Name="bdLog" BorderBrush="LightGray" BorderThickness="1">
        <StackPanel Orientation="Vertical">
            <TextBlock
                Margin="3"
                FontSize="16"
                Foreground="DodgerBlue"
                Text="日志" />
            <Separator Background="LightGray" />
            <RichTextBox
                x:Name="RTB_Logger"
                MaxHeight="150"
                BorderThickness="1"
                IsReadOnly="True"
                VerticalScrollBarVisibility="Auto" />
        </StackPanel>
    </Border>
</UserControl>